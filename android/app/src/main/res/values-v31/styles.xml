<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Theme applied to the Android Window while the process is starting on API 31+ -->
    <style name="LaunchTheme" parent="@android:style/Theme.Light.NoTitleBar">
        <!-- Make the background pure black -->
        <item name="android:windowSplashScreenBackground">@android:color/black</item>
        <!-- Hide the default launcher icon so it transitions seamlessly into the Flutter video -->
        <item name="android:windowSplashScreenAnimatedIcon">@android:color/transparent</item>
        <!-- For older APIs mapped through inheritance, keep it black -->
        <item name="android:windowBackground">@android:color/black</item>
    </style>
    
    <style name="NormalTheme" parent="@android:style/Theme.Light.NoTitleBar">
        <item name="android:windowBackground">?android:colorBackground</item>
    </style>
</resources>
